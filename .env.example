ORIENTDB_HOST=localhost
ORIENTDB_PORT=2480
ORIENTDB_DATABASE=auge
ORIENTDB_USERNAME=root
ORIENTDB_PASSWORD=

# n8n webhook URLs für die Generierungspipeline
N8N_WEBHOOK_GENERIEREN=http://localhost:5678/webhook/auge-generieren

# Wenn gesetzt, wird OrientDB übersprungen und example.json genutzt
USE_EXAMPLE_DATA=true

# ── Live-PR-Status ────────────────────────────────────────────────────────────
# Optional: GitHub Personal Access Token (read:repo) für höheres Rate-Limit.
# Ohne Token: 60 req/h anonym (reicht bei 10-min-Revalidierung).
# Mit Token: 5000 req/h.
# Fine-grained PAT: Repository → Contents: Read, Pull requests: Read
GITHUB_TOKEN=

# ── Service Health (/karte Health-Dots) ──────────────────────────────────────
# Intern (Docker): http://hand:3737, http://gehirn:4000, http://funkner:3100
# Lokal:           http://localhost:3737, etc.
HAND_URL=http://localhost:3737
GEHIRN_URL=http://localhost:4000
FUNKNER_URL=http://localhost:3100
