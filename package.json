{
  "name": "auge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run render-learnings && vite --port 3001 --strictPort --host",
    "render-learnings": "node scripts/render-learnings.mjs",
    "build": "npm run render-learnings && tsc --noEmit && vite build",
    "preview": "vite preview",
    "auto-update": "bash scripts/auto-update.sh",
    "deploy": "npm run build && rsync -avz --delete dist/ claude-user:/home/claude-user/public_html/"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "marked": "^18.0.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
